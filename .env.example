# ============================================================
# FactoryBrain — Environment Configuration
# Copy to .env and adjust values
# ============================================================

# --- Database (TimescaleDB) ---
POSTGRES_USER=factorybrain
POSTGRES_PASSWORD=changeme
POSTGRES_DB=factorybrain
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://factorybrain:changeme@localhost:5432/factorybrain

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- MQTT (Mosquitto) ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_HOST=localhost
MINIO_PORT=9000

# --- Backend ---
SECRET_KEY=change-this-to-a-random-string-in-production
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- External APIs (HomeSense, optional) ---
# FORECAST_SOLAR_API_KEY=       # Optional: for higher rate limits
# ENTSOE_API_KEY=               # For Belpex day-ahead prices
